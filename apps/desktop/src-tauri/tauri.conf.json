{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kaisha",
  "version": "0.1.0",
  "identifier": "com.kaisha.app",
  "build": {
    "beforeDevCommand": "npm --workspace @kaisha/web run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm --workspace @kaisha/web run build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Kaisha",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "shadow": false
      }
    ]
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all"
  }
}
